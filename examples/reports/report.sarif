                  "startColumn": 9
                }
              }
            }
          ],
          "partialFingerprints": {
            "cachemapFindingId": "expensive-before-validation-1"
          },
          "properties": {
            "findingId": "expensive-before-validation-1",
            "kind": "performance",
            "savingsConfidence": "inferred"
          }
        },
        {
          "ruleId": "checkout-persist-credentials",
          "ruleIndex": 9,
          "level": "note",
          "message": {
            "text": "`actions/checkout` persists the GitHub token in the local git config by default. Job `lint` does not appear to push back to the repository, so persisting credentials widens the token's exposure to later steps unnecessarily.\n\nRecommendation: Set `persist-credentials: false` on `actions/checkout` in jobs that do not push to the repository."
          },
          "locations": [
