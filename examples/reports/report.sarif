          },
          "properties": {
            "findingId": "checkout-full-history-1",
            "kind": "performance",
            "savingsConfidence": "inferred"
          }
        },
        {
          "ruleId": "expensive-before-validation",
          "ruleIndex": 8,
          "level": "note",
          "message": {
            "text": "In job `lint`, an expensive step (step 2) runs before a cheap validation step (step 3). If the cheap check often fails, running it first would fail the job sooner and save the expensive work.\n\nRecommendation: Run fast checks (lint, format, typecheck) before expensive build/test steps so failures surface early.\n\nEstimated avoidable time: 0-30s (inferred)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": ".github/workflows/ci.yml",
                  "uriBaseId": "SRCROOT"
                },
                "region": {
